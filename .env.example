# Neptune Apex local controller
APEX_HOST=192.168.1.100
APEX_USER=admin
APEX_PASS=1234

# Neptune Fusion cloud (optional — needed for manual measurement history)
FUSION_USER=your_fusion_username
FUSION_PASS=your_fusion_password
FUSION_APEX_ID=your_apex_id_from_fusion_url

# Home Assistant (optional — needed for sync_measurements_to_ha tool)
HA_URL=http://192.168.1.200:8123
HA_TOKEN=your_long_lived_access_token
